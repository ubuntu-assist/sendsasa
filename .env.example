# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SELF_URL=https://api.sendsasa.com

# ─────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/sendsasa
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=2

# ─────────────────────────────────────────────
# Encryption
# ─────────────────────────────────────────────
# 32-byte hex string used to encrypt wallet keys at rest
ENCRYPTION_KEY=

# ─────────────────────────────────────────────
# WhatsApp Business Cloud API
# ─────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ─────────────────────────────────────────────
# Web3Auth (wallet derivation)
# ─────────────────────────────────────────────
WEB3AUTH_CLIENT_ID=
WEB3AUTH_NETWORK=sapphire_devnet
WEB3AUTH_VERIFIER=

# Internal verifier ID for the admin/platform wallet (not a phone number)
ADMIN_VERIFIER_ID=admin.sendsasa

# ─────────────────────────────────────────────
# JWT (JWKS endpoint — used by Web3Auth)
# ─────────────────────────────────────────────
JWT_KID=
JWT_ISSUER=
JWT_AUDIENCE=
# PEM-encoded ES256 private key (base64 or raw PEM)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ─────────────────────────────────────────────
# Chain RPC URLs
# ─────────────────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BASE_RPC_URL=https://mainnet.base.org
ETHEREUM_RPC_URL=https://eth.llamarpc.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Lisk L2 (OP Stack — chain ID 1135)
LISK_RPC_URL=https://rpc.api.lisk.com
# USDC on Lisk (Circle CCTP) — set after contract deployment
LISK_USDC_ADDRESS=
# USDT on Lisk (Stargate) — set after contract deployment
LISK_USDT_ADDRESS=
# Deployed TrustLock.sol address on Lisk (run: cd contracts/lisk && pnpm deploy:trustlock:testnet)
LISK_TRUSTLOCK_ADDRESS=
# Deployed PayDayBatch.sol address on Lisk (run: cd contracts/lisk && pnpm deploy:payday:testnet)
LISK_PAYDAY_BATCH_ADDRESS=
SOLANA_NETWORK=mainnet-beta

# XRPL (currently disabled — XRPL_ENABLED=false in wallet.service.ts)
XRPL_WSS_URL=wss://s1.ripple.com
XRPL_NETWORK=mainnet

# Admin wallet private key (XRPL — only needed if XRPL_ENABLED=true)
PRIVATE_KEY=

# ─────────────────────────────────────────────
# Stellar
# ─────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Platform Stellar secret key (G... address keypair)
STELLAR_PLATFORM_SECRET=
# Testnet default; replace with mainnet issuer for production
STELLAR_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Soroban contract ID for TrustLock escrow
STELLAR_TRUSTLOCK_CONTRACT_ID=

# ─────────────────────────────────────────────
# Onafriq (off-ramp — XAF MoMo payouts via Stellar anchor)
# ─────────────────────────────────────────────
ONAFRIQ_ANCHOR_URL=https://anchor.onafriq.com
ONAFRIQ_DISTRIBUTION_ACCOUNT=

# ─────────────────────────────────────────────
# pawaPay (mobile money deposits & payouts)
# ─────────────────────────────────────────────
PAWAPAY_API_TOKEN=
PAWAPAY_API_URL=https://api.sandbox.pawapay.io
PAWAPAY_CALLBACK_URL=https://api.sendsasa.com/pawapay/callback

# ─────────────────────────────────────────────
# FX Rates
# ─────────────────────────────────────────────
FIXER_API_KEY=

# ─────────────────────────────────────────────
# Gemini AI (dispute adjudication & NLP parsing)
# ─────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────
# Cloudinary (dispute evidence / media storage)
# ─────────────────────────────────────────────
# Full URL format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

# ─────────────────────────────────────────────
# Onramper (fiat → crypto aggregator)
# ─────────────────────────────────────────────
ONRAMPER_API_KEY=
ONRAMPER_WEBHOOK_SECRET=
ONRAMPER_SIGNING_SECRET=
# Set to 'true' to use Onramper sandbox / test widgets
ONRAMPER_SANDBOX=true

# ─────────────────────────────────────────────
# DEX / Swap APIs
# ─────────────────────────────────────────────
JUPITER_API_KEY=
ONEINCH_API_KEY=

# ─────────────────────────────────────────────
# Coinbase CDP (Apple Pay / headless checkout)
# ─────────────────────────────────────────────
# Set to 'true' to use Coinbase sandbox
COINBASE_HEADLESS_SANDBOX=true
# Sandbox test phone number for Coinbase payments
COINBASE_SANDBOX_PHONE=

# Apple Pay domain verification string (from Coinbase CDP dashboard)
APPLE_PAY_DOMAIN_VERIFICATION=

# ─────────────────────────────────────────────
# MoMo Trust (fees & support)
# ─────────────────────────────────────────────
# Decimal fee rate (default 1%)
MOMOTRUST_FEE_PERCENT=0.01
# WhatsApp number for support escalation (E.164 format, e.g. 237XXXXXXXXX)
SUPPORT_WA_NUMBER=

# ─────────────────────────────────────────────
# WhatsApp Flow IDs (register in Meta dashboard)
# ─────────────────────────────────────────────
SEND_MONEY_FLOW_ID=
OFFRAMP_FLOW_ID=
REQUEST_MONEY_FLOW_ID=
CARD_PAYMENT_FLOW_ID=
PIN_SETUP_FLOW_ID=
MANAGE_CONTACTS_FLOW_ID=
REQUEST_CARD_FLOW_ID=
FLOW_ID_PIN_CONFIRM=
FLOW_ID_STATEMENT=
WELCOME_VIDEO_ID=

# MoMo Trust feature flows
FLOW_ID_TRUSTLOCK_CREATE=
FLOW_ID_NJANGI_CREATE=
FLOW_ID_SPLITCHAT_CREATE=
FLOW_ID_PAYDAY_CREATE=
FLOW_ID_SAFIPAY_CREATE=
FLOW_ID_DISPUTE_FILE=
FLOW_ID_KOBOKALL_SEND=
FLOW_ID_CRYPTO_SWAP=
