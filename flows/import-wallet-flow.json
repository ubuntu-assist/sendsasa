{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "IMPORT_WALLET_SEED": ["IMPORT_WALLET_CONFIRM"],
    "IMPORT_WALLET_CONFIRM": []
  },
  "screens": [
    {
      "id": "IMPORT_WALLET_SEED",
      "title": "Import Wallet",
      "sensitive": ["seed"],
      "data": {
        "error_seed": {
          "type": "string",
          "__example__": ""
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Enter Your Seed"
          },
          {
            "type": "TextBody",
            "text": "Enter your XRPL family seed to import your existing wallet. It starts with the letter s."
          },
          {
            "type": "TextBody",
            "text": "Never share your seed with anyone. SendSasa encrypts it immediately and never stores it in plain text."
          },
          {
            "type": "Form",
            "name": "seed_form",
            "error-messages": {
              "seed": "${data.error_seed}"
            },
            "children": [
              {
                "type": "TextInput",
                "name": "seed",
                "label": "Family Seed",
                "input-type": "password",
                "required": true,
                "helper-text": "Starts with s — e.g. sEd7..."
              },
              {
                "type": "Footer",
                "label": "Validate Seed",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "seed": "${form.seed}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "IMPORT_WALLET_CONFIRM",
      "title": "Confirm Import",
      "terminal": true,
      "success": true,
      "data": {
        "xrpl_address": {
          "type": "string",
          "__example__": "rDr42a4zCQtvgyPqdDv12cZ1zaZ4BfigBp"
        },
        "xrp_balance": {
          "type": "string",
          "__example__": "25.50"
        },
        "seed": {
          "type": "string",
          "__example__": "sEd7..."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Wallet Found!"
          },
          {
            "type": "TextBody",
            "text": "We found your wallet. Please confirm this is the correct address before importing."
          },
          {
            "type": "TextBody",
            "text": "`'Address: ' ${data.xrpl_address}`"
          },
          {
            "type": "TextBody",
            "text": "`'Balance: ' ${data.xrp_balance} ' XRP'`"
          },
          {
            "type": "Form",
            "name": "confirm_form",
            "children": [
              {
                "type": "Footer",
                "label": "Import This Wallet",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "seed": "${data.seed}",
                    "xrpl_address": "${data.xrpl_address}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
