{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "INVOICE_DETAILS": ["INVOICE_CONFIRM", "SELECT_CLIENT_CONTACT"],
    "SELECT_CLIENT_CONTACT": ["INVOICE_CONFIRM"],
    "INVOICE_CONFIRM": []
  },
  "screens": [
    {
      "id": "INVOICE_DETAILS",
      "title": "Create an Invoice",
      "data": {
        "error_recipient_type": { "type": "string", "__example__": "" },
        "error_client_phone": { "type": "string", "__example__": "" },
        "error_description": { "type": "string", "__example__": "" },
        "error_total": { "type": "string", "__example__": "" },
        "error_due_date": { "type": "string", "__example__": "" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "New Invoice"
          },
          {
            "type": "TextBody",
            "text": "The invoice will be sent to your client with a MoMo payment link."
          },
          {
            "type": "Dropdown",
            "label": "Client",
            "name": "recipient_type",
            "required": true,
            "error-message": "${data.error_recipient_type}",
            "data-source": [
              { "id": "Phone Number", "title": "Phone Number" },
              { "id": "Saved Contact", "title": "Saved Contacts" }
            ]
          },
          {
            "type": "TextInput",
            "label": "Client's Phone",
            "name": "client_phone",
            "required": false,
            "input-type": "phone",
            "visible": "`${form.recipient_type} == 'Phone Number'`",
            "error-message": "${data.error_client_phone}"
          },
          {
            "type": "TextInput",
            "label": "Client Name (optional)",
            "name": "client_name",
            "required": false,
            "input-type": "text"
          },
          {
            "type": "TextArea",
            "label": "Description / service",
            "name": "description",
            "required": true,
            "helper-text": "e.g. Samsung S21 phone repair",
            "error-message": "${data.error_description}"
          },
          {
            "type": "TextInput",
            "label": "Total Amount (XAF)",
            "name": "total",
            "required": true,
            "input-type": "number",
            "error-message": "${data.error_total}"
          },
          {
            "type": "DatePicker",
            "label": "Due Date",
            "name": "due_date",
            "required": true,
            "error-message": "${data.error_due_date}"
          },
          {
            "type": "Footer",
            "label": "See Summary",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "recipient_type": "${form.recipient_type}",
                "client_phone": "${form.client_phone}",
                "client_name": "${form.client_name}",
                "description": "${form.description}",
                "total": "${form.total}",
                "due_date": "${form.due_date}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SELECT_CLIENT_CONTACT",
      "title": "Select Client",
      "data": {
        "client_name": { "type": "string", "__example__": "" },
        "description": { "type": "string", "__example__": "Phone repair" },
        "total": { "type": "string", "__example__": "25000" },
        "due_date": { "type": "string", "__example__": "2025-01-31" },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [{ "id": "237612345678", "title": "John (237612345678)" }]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Select Client"
          },
          {
            "type": "Dropdown",
            "name": "contact",
            "label": "Choose from saved contacts",
            "required": true,
            "data-source": "${data.contacts}"
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "client_name": "${data.client_name}",
                "description": "${data.description}",
                "total": "${data.total}",
                "due_date": "${data.due_date}",
                "contact": "${form.contact}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "INVOICE_CONFIRM",
      "title": "Confirm Invoice",
      "terminal": true,
      "data": {
        "client_phone": { "type": "string", "__example__": "237653456789" },
        "client_name": { "type": "string", "__example__": "" },
        "description": { "type": "string", "__example__": "Phone repair" },
        "total": { "type": "string", "__example__": "25000" },
        "due_date": { "type": "string", "__example__": "2025-01-31" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Invoice Summary"
          },
          { "type": "TextCaption", "text": "· · · · · · · · · ·" },
          { "type": "TextSubheading", "text": "Description" },
          { "type": "TextBody", "text": "${data.description}" },
          { "type": "TextSubheading", "text": "Client" },
          { "type": "TextBody", "text": "${data.client_phone}" },
          { "type": "TextSubheading", "text": "Amount" },
          { "type": "TextBody", "text": "`${data.total} ' XAF'`" },
          { "type": "TextSubheading", "text": "Due Date" },
          { "type": "TextBody", "text": "${data.due_date}" },
          { "type": "TextCaption", "text": "· · · · · · · · · ·" },
          { "type": "TextBody", "text": "The client will receive a MoMo payment link." },
          {
            "type": "Footer",
            "label": "Send Invoice",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "client_phone": "${data.client_phone}",
                "client_name": "${data.client_name}",
                "description": "${data.description}",
                "total": "${data.total}",
                "due_date": "${data.due_date}"
              }
            }
          }
        ]
      }
    }
  ]
}
