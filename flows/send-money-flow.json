{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "SEND_MONEY_DETAILS": ["SEND_MONEY_CONFIRM"],
    "SEND_MONEY_CONFIRM": ["SEND_MONEY_SUCCESS"],
    "SEND_MONEY_SUCCESS": []
  },
  "screens": [
    {
      "id": "SEND_MONEY_DETAILS",
      "title": "Send Money",
      "data": {
        "available_balance": {
          "type": "string",
          "__example__": "100.50 XRP"
        },
        "error_currency": {
          "type": "string",
          "__example__": ""
        },
        "error_amount": {
          "type": "string",
          "__example__": ""
        },
        "error_recipient_type": {
          "type": "string",
          "__example__": ""
        },
        "error_recipient": {
          "type": "string",
          "__example__": ""
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Available Balance"
          },
          {
            "type": "TextBody",
            "text": "${data.available_balance}"
          },
          {
            "type": "Form",
            "name": "send_money_form",
            "error-messages": {
              "currency": "${data.error_currency}",
              "amount": "${data.error_amount}",
              "recipient_type": "${data.error_recipient_type}",
              "recipient": "${data.error_recipient}"
            },
            "children": [
              {
                "type": "Dropdown",
                "name": "currency",
                "label": "Currency",
                "required": true,
                "data-source": [
                  { "id": "XRP",      "title": "XRP (XRPL)" },
                  { "id": "RLUSD",    "title": "RLUSD (Ripple USD)" },
                  { "id": "USDC",     "title": "USDC (XRPL)" },
                  { "id": "BNB",      "title": "BNB (BSC)" },
                  { "id": "USDT",     "title": "USDT (BSC)" },
                  { "id": "USDC_BSC", "title": "USDC (BSC)" },
                  { "id": "SOL",      "title": "SOL (Solana)" },
                  { "id": "USDC_SOL", "title": "USDC (Solana)" },
                  { "id": "USDT_SOL", "title": "USDT (Solana)" },
                  { "id": "EURC_SOL", "title": "EURC (Solana)" }
                ]
              },
              {
                "type": "TextInput",
                "name": "amount",
                "label": "Amount",
                "input-type": "number",
                "required": true
              },
              {
                "type": "Dropdown",
                "name": "recipient_type",
                "label": "Send To",
                "required": true,
                "data-source": [
                  { "id": "Phone Number",      "title": "Phone Number" },
                  { "id": "SendSasa Username", "title": "SendSasa Username" },
                  { "id": "Wallet Address",    "title": "Wallet Address" }
                ]
              },
              {
                "type": "TextInput",
                "name": "recipient",
                "label": "Recipient",
                "input-type": "text",
                "required": true,
                "helper-text": "Phone (+237...), username (@john) or wallet address"
              },
              {
                "type": "Footer",
                "label": "Continue",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "currency":       "${form.currency}",
                    "amount":         "${form.amount}",
                    "recipient_type": "${form.recipient_type}",
                    "recipient":      "${form.recipient}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SEND_MONEY_CONFIRM",
      "title": "Confirm Transaction",
      "data": {
        "currency": {
          "type": "string",
          "__example__": "XRP"
        },
        "amount": {
          "type": "string",
          "__example__": "10.5"
        },
        "recipient_type": {
          "type": "string",
          "__example__": "Phone Number"
        },
        "recipient": {
          "type": "string",
          "__example__": "+237676535501"
        },
        "recipient_display": {
          "type": "string",
          "__example__": "+237676535501"
        },
        "fee": {
          "type": "string",
          "__example__": "0.010500"
        },
        "total": {
          "type": "string",
          "__example__": "10.510500"
        },
        "error_transaction_pin": {
          "type": "string",
          "__example__": ""
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Review Transaction"
          },
          {
            "type": "TextBody",
            "text": "`'Amount: ' ${data.amount} ' ' ${data.currency}`"
          },
          {
            "type": "TextBody",
            "text": "`'Fee: ' ${data.fee} ' ' ${data.currency}`"
          },
          {
            "type": "TextBody",
            "text": "`'Total: ' ${data.total} ' ' ${data.currency}`"
          },
          {
            "type": "TextBody",
            "text": "`'To: ' ${data.recipient_display}`"
          },
          {
            "type": "Form",
            "name": "confirm_form",
            "error-messages": {
              "transaction_pin": "${data.error_transaction_pin}"
            },
            "children": [
              {
                "type": "TextInput",
                "name": "transaction_pin",
                "label": "Transaction PIN",
                "input-type": "passcode",
                "required": true,
                "min-chars": 4,
                "max-chars": 6,
                "helper-text": "Enter your 4-6 digit PIN to confirm"
              },
              {
                "type": "Footer",
                "label": "Send Money",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "currency":          "${data.currency}",
                    "amount":            "${data.amount}",
                    "recipient_type":    "${data.recipient_type}",
                    "recipient":         "${data.recipient}",
                    "recipient_display": "${data.recipient_display}",
                    "fee":               "${data.fee}",
                    "total":             "${data.total}",
                    "transaction_pin":   "${form.transaction_pin}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SEND_MONEY_SUCCESS",
      "title": "Payment Initiated",
      "terminal": true,
      "success": true,
      "data": {
        "currency": {
          "type": "string",
          "__example__": "XRP"
        },
        "amount": {
          "type": "string",
          "__example__": "10.5"
        },
        "total": {
          "type": "string",
          "__example__": "10.510500"
        },
        "recipient_display": {
          "type": "string",
          "__example__": "+237676535501"
        },
        "recipient_type": {
          "type": "string",
          "__example__": "Phone Number"
        },
        "recipient": {
          "type": "string",
          "__example__": "+237676535501"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "✅ Payment Initiated!"
          },
          {
            "type": "TextBody",
            "text": "`'Sending ' ${data.total} ' ' ${data.currency} ' to ' ${data.recipient_display}`"
          },
          {
            "type": "TextBody",
            "text": "Your transaction is being processed. You will receive a confirmation message shortly."
          },
          {
            "type": "Form",
            "name": "success_form",
            "children": [
              {
                "type": "Footer",
                "label": "Done",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "currency":          "${data.currency}",
                    "amount":            "${data.amount}",
                    "total":             "${data.total}",
                    "recipient_display": "${data.recipient_display}",
                    "recipient_type":    "${data.recipient_type}",
                    "recipient":         "${data.recipient}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
