{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "KOBOKALL_SEND": ["KOBOKALL_CONFIRM", "SELECT_RECIPIENT_CONTACT"],
    "SELECT_RECIPIENT_CONTACT": ["KOBOKALL_CONFIRM"],
    "KOBOKALL_CONFIRM": []
  },
  "screens": [
    {
      "id": "KOBOKALL_SEND",
      "title": "MoMo Transfer",
      "data": {
        "error_recipient_type": { "type": "string", "__example__": "" },
        "error_recipient_phone": { "type": "string", "__example__": "" },
        "error_send_amount": { "type": "string", "__example__": "" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Dropdown",
            "name": "recipient_type",
            "label": "Recipient",
            "required": true,
            "error-message": "${data.error_recipient_type}",
            "data-source": [
              { "id": "Phone Number", "title": "Phone Number" },
              { "id": "Saved Contact", "title": "Saved Contacts" }
            ]
          },
          {
            "type": "TextInput",
            "name": "recipient_phone",
            "label": "Recipient Phone (e.g. 237653456789)",
            "input-type": "phone",
            "required": false,
            "visible": "`${form.recipient_type} == 'Phone Number'`",
            "error-message": "${data.error_recipient_phone}"
          },
          {
            "type": "TextInput",
            "name": "send_amount",
            "label": "Amount to Send (XAF)",
            "input-type": "number",
            "required": true,
            "error-message": "${data.error_send_amount}"
          },
          {
            "type": "Footer",
            "label": "See Summary",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "recipient_type": "${form.recipient_type}",
                "recipient_phone": "${form.recipient_phone}",
                "send_amount": "${form.send_amount}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SELECT_RECIPIENT_CONTACT",
      "title": "Select Recipient",
      "data": {
        "send_amount": { "type": "string", "__example__": "5000" },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [{ "id": "237653456789", "title": "John (237653456789)" }]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Dropdown",
            "name": "contact",
            "label": "Choose from saved contacts",
            "required": true,
            "data-source": "${data.contacts}"
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "send_amount": "${data.send_amount}",
                "contact": "${form.contact}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "KOBOKALL_CONFIRM",
      "title": "Confirm Transfer",
      "terminal": true,
      "data": {
        "recipient_phone": { "type": "string", "__example__": "237653456789" },
        "send_amount": { "type": "string", "__example__": "5000" },
        "net_amount": { "type": "string", "__example__": "4950" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Transfer Summary"
          },
          { "type": "TextCaption", "text": "· · · · · · · · · ·" },
          { "type": "TextSubheading", "text": "Recipient" },
          { "type": "TextBody", "text": "${data.recipient_phone}" },
          { "type": "TextSubheading", "text": "You Send" },
          { "type": "TextBody", "text": "`${data.send_amount} ' XAF'`" },
          { "type": "TextSubheading", "text": "They Receive" },
          { "type": "TextBody", "text": "`${data.net_amount} ' XAF'`" },
          { "type": "TextCaption", "text": "· · · · · · · · · ·" },
          {
            "type": "Footer",
            "label": "Confirm",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "recipient_phone": "${data.recipient_phone}",
                "send_amount": "${data.send_amount}",
                "net_amount": "${data.net_amount}"
              }
            }
          }
        ]
      }
    }
  ]
}
