{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "KOBOKALL_SEND": ["KOBOKALL_CONFIRM", "SELECT_RECIPIENT_CONTACT"],
    "SELECT_RECIPIENT_CONTACT": ["KOBOKALL_CONFIRM"],
    "KOBOKALL_CONFIRM": []
  },
  "screens": [
    {
      "id": "KOBOKALL_SEND",
      "title": "MoMo Transfer",
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Dropdown",
            "name": "recipient_type",
            "label": "Recipient",
            "required": true,
            "data-source": [
              { "id": "Phone Number", "title": "Enter phone number" },
              { "id": "Saved Contact", "title": "Choose from saved contacts" }
            ]
          },
          {
            "type": "TextInput",
            "name": "recipient_phone",
            "label": "Recipient Phone (e.g. 237653456789)",
            "input-type": "phone",
            "required": true,
            "visible": "`${form.recipient_type} == 'Phone Number'`"
          },
          {
            "type": "TextInput",
            "name": "send_amount",
            "label": "Amount to Send (XAF)",
            "input-type": "number",
            "required": true
          },
          {
            "type": "Footer",
            "label": "See Summary",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "recipient_type": "${form.recipient_type}",
                "recipient_phone": "${form.recipient_phone}",
                "send_amount": "${form.send_amount}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SELECT_RECIPIENT_CONTACT",
      "title": "Select Recipient",
      "data": {
        "send_amount": { "type": "string", "__example__": "5000" },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [{ "id": "237653456789", "title": "John (237653456789)" }]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Dropdown",
            "name": "contact",
            "label": "Choose from saved contacts",
            "required": true,
            "data-source": "${data.contacts}"
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "send_amount": "${data.send_amount}",
                "contact": "${form.contact}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "KOBOKALL_CONFIRM",
      "title": "Confirm Transfer",
      "terminal": true,
      "data": {
        "recipient_phone": { "type": "string", "__example__": "237653456789" },
        "send_amount": { "type": "string", "__example__": "5000" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Transfer Summary"
          },
          {
            "type": "TextBody",
            "text": "Recipient: ${data.recipient_phone}\nAmount: ${data.send_amount} XAF\n\nFee and final amount will be shown before payment."
          },
          {
            "type": "Footer",
            "label": "Send",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "recipient_phone": "${data.recipient_phone}",
                "send_amount": "${data.send_amount}"
              }
            }
          }
        ]
      }
    }
  ]
}
